# OutbreakSense AI deployment reference (non-Docker)

# ----------------------
# Backend (Render)
# ----------------------
NODE_ENV=production
PORT=5050
MONGO_URI=mongodb+srv://<USER>:<PASS>@<CLUSTER>/<DB>?retryWrites=true&w=majority
JWT_SECRET=<replace-with-strong-32-char-secret>
JWT_EXPIRES_IN=1d
AI_ENGINE_URL=https://<ai-engine-service>.onrender.com
CORS_ORIGIN=https://<web-app>.vercel.app
SOCKET_CORS_ORIGIN=https://<web-app>.vercel.app
BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=12
TRUST_PROXY=true
SEED_DEFAULT_ADMIN=true
DEFAULT_ADMIN_EMAIL=admin@outbreaksense.ai
DEFAULT_ADMIN_PASSWORD=<strong-password>

# ----------------------
# AI Engine (Render)
# ----------------------
# PORT=8001
# MODEL_TYPE=random_forest
# MODEL_PATH=model/risk_model.joblib
# DATASET_PATH=data/dengue_sample_data.csv

# ----------------------
# Web (Vercel)
# ----------------------
# VITE_API_BASE_URL=https://<backend-service>.onrender.com/api
# VITE_SOCKET_URL=https://<backend-service>.onrender.com
