# AI Engine Configuration
PORT=8001
NODE_ENV=production

# Model Configuration
MODEL_TYPE=random_forest
MODEL_PATH=model/risk_model.joblib

# Security
API_KEY=sk-ai-prod-your-key-change-this-to-random-value
ENABLE_AUTH=true

# Logging
LOG_LEVEL=info

# Request Limits
MAX_BATCH_SIZE=300
REQUEST_TIMEOUT_MS=9000

# CORS
CORS_ORIGINS=your-backend-url:5050
