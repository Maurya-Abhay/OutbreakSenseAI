# Server Configuration
PORT=5050
NODE_ENV=development

# MongoDB (use MongoDB Atlas or local instance)
MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/outbreaksense

# JWT Secrets (use strong random values - minimum 32 characters each)
JWT_SECRET=your-long-random-secret-key-minimum-32-characters
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your-long-random-refresh-secret-minimum-32-characters
JWT_REFRESH_EXPIRES_IN=7d

# AI Engine Configuration
AI_ENGINE_URL=http://127.0.0.1:8001
AI_ENGINE_API_KEY=sk-ai-prod-your-key-here

# CORS Configuration (comma-separated list of allowed origins)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8081
SOCKET_CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8081

# Default Admin User (auto-seeded on startup if SEED_DEFAULT_ADMIN=true)
DEFAULT_ADMIN_EMAIL=admin@nhs19.local
DEFAULT_ADMIN_PASSWORD=Admin@123

# Email Configuration (choose one provider: gmail or sendgrid)
# Gmail: Use an App Password (not regular password)
# See: https://myaccount.google.com/apppasswords
EMAIL_PROVIDER=gmail
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password-here
EMAIL_FROM=your-email@gmail.com

# SendGrid (alternative to Gmail)
SENDGRID_API_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=12

# Request Body Limit
BODY_LIMIT=1mb

# Proxy Trust (set to true if behind reverse proxy/load balancer)
TRUST_PROXY=false

# Seeding
SEED_DEFAULT_ADMIN=true

# Logging
LOG_LEVEL=info

# Caching
CACHE_TTL_MINUTES=15
CACHE_MAX_SIZE=1000
PORT=5050
MONGO_URI=mongodb://127.0.0.1:27017/outbreaksense
JWT_SECRET=replace_with_a_long_secure_secret
JWT_EXPIRES_IN=1d
AI_ENGINE_URL=http://127.0.0.1:8001
CORS_ORIGIN=http://localhost:5173,http://localhost:8081
SOCKET_CORS_ORIGIN=http://localhost:5173,http://localhost:8081
BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=12
TRUST_PROXY=false
SEED_DEFAULT_ADMIN=true
DEFAULT_ADMIN_EMAIL=admin@outbreaksense.ai
DEFAULT_ADMIN_PASSWORD=Admin@123

# Email / OTP configuration
EMAIL_PROVIDER=gmail
EMAIL_FROM=no-reply@outbreaksense.ai
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Alternative providers (use one provider at a time)
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
